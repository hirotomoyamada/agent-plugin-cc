{
  "name": "@cursor/agent-plugin-cc",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Use Cursor Agent from Claude Code to review code or delegate tasks.",
  "license": "MIT",
  "author": "Hirotomo Yamada <hirotomo.yamada@avap.co.jp>",
  "repository": {
    "type": "git",
    "url": "https://github.com/hirotomoyamada/cursor-agent-plugin"
  },
  "engines": {
    "node": ">=24.14"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format .",
    "check": "biome check .",
    "clean": "rimraf node_modules plugins/agent/scripts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
