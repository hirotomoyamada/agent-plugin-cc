{
  "name": "agent-plugin-cc",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-AI plugins for Claude Code: drive Cursor Agent, OpenAI Codex, or Moonshot Kimi from inside Claude Code for code review and task delegation.",
  "license": "MIT",
  "author": "Hirotomo Yamada <hirotomo.yamada@avap.co.jp>",
  "repository": {
    "type": "git",
    "url": "https://github.com/hirotomoyamada/cursor-agent-plugin"
  },
  "engines": {
    "node": ">=24.14"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm build:agent && pnpm build:codex && pnpm build:kimi",
    "build:agent": "tsgo -p tsconfig.agent.json && tsgo -p tsconfig.agent-core.json",
    "build:codex": "tsgo -p tsconfig.codex.json && tsgo -p tsconfig.codex-core.json",
    "build:kimi": "tsgo -p tsconfig.kimi.json && tsgo -p tsconfig.kimi-core.json",
    "typecheck": "pnpm typecheck:agent && pnpm typecheck:codex && pnpm typecheck:kimi",
    "typecheck:agent": "tsgo -p tsconfig.agent.json --noEmit && tsgo -p tsconfig.agent-core.json --noEmit",
    "typecheck:codex": "tsgo -p tsconfig.codex.json --noEmit && tsgo -p tsconfig.codex-core.json --noEmit",
    "typecheck:kimi": "tsgo -p tsconfig.kimi.json --noEmit && tsgo -p tsconfig.kimi-core.json --noEmit",
    "lint:check": "oxlint . --max-warnings=0",
    "lint:fix": "oxlint . --max-warnings=0 --fix",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "clean": "rimraf node_modules",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^25.7.0",
    "@typescript/native-preview": "7.0.0-dev.20260513.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "rimraf": "^6.1.3"
  }
}
