{
  "name": "@cursor/agent-plugin-cc",
  "type": "module",
  "version": "1.1.1",
  "private": true,
  "description": "Use Cursor Agent from Claude Code to review code or delegate tasks.",
  "license": "MIT",
  "author": "Hirotomo Yamada <hirotomo.yamada@avap.co.jp>",
  "repository": {
    "type": "git",
    "url": "https://github.com/hirotomoyamada/cursor-agent-plugin"
  },
  "engines": {
    "node": ">=24.14"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsgo",
    "typecheck": "tsgo --noEmit",
    "lint:check": "oxlint . --max-warnings=0",
    "lint:fix": "oxlint . --max-warnings=0 --fix",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "clean": "rimraf node_modules plugins/agent/scripts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^25.7.0",
    "@typescript/native-preview": "7.0.0-dev.20260513.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "rimraf": "^6.1.3"
  }
}
